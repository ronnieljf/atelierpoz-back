# Database
DATABASE_URL=postgresql://user:password@localhost:5432/atelierpoz

# JWT
JWT_SECRET=your-secret-key-here

# WhatsApp Business API (Meta)
WS_token=YOUR_META_ACCESS_TOKEN
WHATSAPP_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID
WHATSAPP_VERIFY_TOKEN=YOUR_VERIFY_TOKEN

# Groq AI (rápido y eficiente)
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE

# Google Gemini AI (alternativa)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# AWS S3 (opcional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Domain
DOMAIN=https://atelierpoz.com

# URLs (producción: usar HTTPS para OAuth Instagram)
BACKEND_URL=https://api.atelierpoz.com
FRONTEND_URL=https://atelierpoz.com

# Meta / Instagram OAuth (conectar cuenta para publicar posts)
META_APP_ID=
META_APP_SECRET=

# R2 público (imágenes de posts deben ser URL pública para publicar en Instagram)
R2_PUBLIC_URL=

# BCV Service (optional)
BCV_API_URL=https://pydolarve.org/api/v1/dollar?page=bcv

# Recordatorios: expresión cron (por defecto "0 9 * * *" = diario a las 9:00). Ver https://www.npmjs.com/package/node-cron
# REMINDER_JOB_CRON=0 9 * * *

# SMTP - Correo para verificación de email y recuperación de contraseña
# Ejecutar migración 041 antes: node src/db/migrations/041_email_verification_and_password_reset.js
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-app-password
SMTP_FROM=Atelier Poz <noreply@atelierpoz.com>
